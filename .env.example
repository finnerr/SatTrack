# CelesTrak proxy base URL for TLE catalog refresh.
# In development this is handled by the Vite dev server proxy (vite.config.ts) —
# leave unset or set to /celestrak.
# In production, point this at a server-side proxy that forwards to https://celestrak.org
# and sets an appropriate User-Agent header.
# VITE_CELESTRAK_BASE=https://your-proxy.example.com/celestrak
